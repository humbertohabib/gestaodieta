<%- include('partials/head') %>

<main class="dashboard-shell">
  <aside class="sidebar">
    <span class="sidebar-title">Admin Geral</span>
    <a href="#indicadores">Indicadores</a>
    <a href="#leads">Leads</a>
    <a href="#usuarios">Usuarios</a>
    <a href="#historico">Historico</a>
  </aside>

  <section class="dashboard-content">
    <div class="page-heading">
      <div>
        <p class="eyebrow">Controle operacional</p>
        <h1>Painel do Administrador</h1>
      </div>
      <span class="status-pill">Banco em memoria</span>
    </div>

    <section id="indicadores" class="kpi-grid">
      <article><span>Leads</span><strong><%= stats.totalLeads %></strong></article>
      <article><span>Pagos</span><strong><%= stats.paidLeads %></strong></article>
      <article><span>Conversao</span><strong><%= stats.conversionRate %>%</strong></article>
      <article><span>Pacientes</span><strong><%= stats.patients %></strong></article>
      <article><span>Dietas</span><strong><%= stats.diets %></strong></article>
      <article><span>Usuarios ativos</span><strong><%= stats.activeUsers %></strong></article>
    </section>

    <section id="leads" class="panel">
      <div class="section-heading">
        <h2>Leads e pagamentos</h2>
        <span><%= leads.length %> registros</span>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Nome</th>
              <th>Contato</th>
              <th>Plano</th>
              <th>Status</th>
              <th>Acao</th>
            </tr>
          </thead>
          <tbody>
            <% leads.forEach((lead) => { %>
              <tr>
                <td><strong><%= lead.name %></strong><small><%= lead.goal %></small></td>
                <td><%= lead.email %><small><%= lead.phone %></small></td>
                <td><%= lead.plan %></td>
                <td><span class="status-pill <%= lead.paid ? 'ok' : '' %>"><%= lead.status %></span></td>
                <td>
                  <% if (!lead.paid) { %>
                    <form method="post" action="/admin/leads/<%= lead.id %>/payment">
                      <button class="small-action" type="submit">Marcar pago</button>
                    </form>
                  <% } else { %>
                    <span class="muted">Liberado</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>

    <section id="usuarios" class="panel">
      <div class="section-heading">
        <h2>Usuarios do sistema</h2>
        <span>Permissoes por perfil</span>
      </div>
      <div class="user-grid">
        <% users.forEach((user) => { %>
          <article class="user-card">
            <div>
              <strong><%= user.name %></strong>
              <span><%= user.email %></span>
            </div>
            <span class="status-pill <%= user.active ? 'ok' : '' %>"><%= user.role %> / <%= user.active ? 'ativo' : 'inativo' %></span>
            <% if (user.role !== 'admin') { %>
              <form method="post" action="/admin/users/<%= user.id %>/toggle">
                <button class="small-action" type="submit"><%= user.active ? 'Inativar' : 'Ativar' %></button>
              </form>
            <% } %>
          </article>
        <% }) %>
      </div>
    </section>

    <section id="historico" class="panel">
      <div class="section-heading">
        <h2>Historico detalhado</h2>
        <span>Eventos recentes</span>
      </div>
      <ol class="timeline">
        <% events.forEach((event) => { %>
          <li>
            <span><%= event.type %></span>
            <strong><%= event.message %></strong>
            <time><%= new Date(event.createdAt).toLocaleString('pt-BR') %></time>
          </li>
        <% }) %>
      </ol>
    </section>
  </section>
</main>

<%- include('partials/end') %>
